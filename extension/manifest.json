{
  "manifest_version": 3,
  "name": "CarFind — Marketplace Collector",
  "version": "1.0",
  "description": "אוסף מודעות רכב מ-Facebook Marketplace ושולח ל-CarFind",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://carfind-backend.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/marketplace/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CarFind"
  },
  "background": {
    "service_worker": "background.js"
  }
}
